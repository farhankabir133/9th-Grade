# Supabase Configuration
# Server-side (API routes, repositories, services)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side (browser bundle - must be prefixed with VITE_ for Vite to inject)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI Configuration
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Groq Open Model Configuration
GROQ_API_KEY=MY_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPEN_MODEL_PRIMARY=llama-3.3-70b-versatile
OPEN_MODEL_FALLBACK=qwen-2.5-72b-instruct

# Replenishment Configuration
REPLENISH_SECRET=MY_REPLENISH_SECRET
MINIMUM_STOCK_THRESHOLD=30
SCHEDULE_FREQUENCY=0 21 * * *

# App URL
APP_URL=MY_APP_URL
